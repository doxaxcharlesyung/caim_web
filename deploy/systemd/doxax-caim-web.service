[Unit]
Description=DoxaX CAIM Web Flask via Gunicorn
After=network.target

[Service]
User=cyung
Group=cyung
WorkingDirectory=/opt/caim_web
Environment=FLASK_ENV=production
EnvironmentFile=-/opt/caim_web/.env
ExecStart=/opt/caim_web/.venv/bin/gunicorn --workers 3 --bind 127.0.0.1:18003 --access-logfile - --error-logfile - wsgi:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
