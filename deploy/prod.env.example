# Copy this template to /opt/caim_web/.env on the production server.
# Do not commit the populated file. It must be owner-readable only (chmod 0600).

APP_ENV=production
SECRET_KEY=replace-with-a-long-random-value

CRM_API_URL=https://dxcrm.doxaxsolutions.com/api/v1/public/consultation-intake
CRM_CONSULTATION_TOKEN=replace-with-the-crm-token
CRM_ACTIVITY_REGISTRATION_URL=https://dxcrm.doxaxsolutions.com/api/v1/public/activity-registration
CRM_ACTIVITY_TOKEN=replace-with-the-activity-form-token
CRM_TIMEOUT_SECONDS=15

# LibreTranslate-compatible server-side translation endpoint.
TRANSLATION_API_URL=https://translation.example.com/translate
TRANSLATION_API_KEY=replace-with-translation-api-key

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=caimadmin
DB_PASSWORD=replace-with-the-caimadmin-password
DB_NAME=caimdb

# Used by scripts/create_prod_database.py during deployment bootstrap.
MYSQL_ADMIN_USER=root
MYSQL_ADMIN_PASSWORD=replace-with-a-mysql-admin-password
# Optional when root uses socket authentication instead of TCP:
# MYSQL_ADMIN_SOCKET=/var/lib/mysql/mysql.sock
